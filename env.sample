# tailor-swift environment configuration
#
# Copy this file to `.env`, fill in your keys, then load it into your shell:
#
#   cp env.sample .env
#   set -a; source .env; set +a     # exports every var for the current shell
#
# `.env` is gitignored so your real keys never get committed.

# --- Embeddings (always required) -------------------------------------------
# Voyage powers achievement retrieval; the command exits 1 without this.
VOYAGE_API_KEY=

# Optional. Defaults to voyage-3 when unset.
VOYAGE_MODEL=voyage-3

# --- Generation provider key ------------------------------------------------
# Which key you need depends on `--provider` (default: openrouter).

# Default provider. Required unless you pass `--provider anthropic`.
OPENROUTER_API_KEY=

# Only needed when you run with `--provider anthropic`.
ANTHROPIC_API_KEY=
